rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // only via Cloud Functions
    }
    match /materials/{materialId} {
      allow read: if true; // 누구나 자료 목록/상세 조회 가능
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    match /transactions/{txId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.buyerId == request.auth.uid;
      allow write: if false;
    }
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 1000;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /kakaopay_sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // server only
    }
    match /toss_sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // server only
    }
    match /carts/{cartId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /reports/{reportId} {
      allow read, write: if false; // Cloud Functions only (submit, admin)
    }
    match /withdraw_secrets/{docId} {
      allow read, write: if false; // Cloud Functions only (admin)
    }
    match /verification_sessions/{docId} {
      allow read, write: if false; // Cloud Functions only
    }
    match /admin_logs/{docId} {
      allow read, write: if false; // Cloud Functions only
    }
    match /failed_deletions/{docId} {
      allow read, write: if false; // Cloud Functions only
    }
    match /material_requests/{requestId} {
      allow read: if true; // 누구나 요청 목록 조회 가능
      allow write: if false; // only via Cloud Functions
    }
  }
}
