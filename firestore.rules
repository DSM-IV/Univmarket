rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 여부 (users/{uid}.role == 'admin')
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // only via Cloud Functions
    }

    match /materials/{materialId} {
      allow read: if true; // 누구나 자료 목록/상세 조회 가능

      // 자료 등록: 가격은 정수, 0~500,000 범위, 통계 필드는 0으로 시작해야 함
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.price is int
        && request.resource.data.price >= 0
        && request.resource.data.price <= 500000
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.salesCount == 0
        && request.resource.data.rating == 0
        && request.resource.data.reviewCount == 0;

      // 작성자 본인은 안전한 필드만 수정 가능 (가격/통계 조작 방지)
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'title', 'description', 'price', 'subject', 'professor',
              'department', 'semester', 'category', 'tags', 'pages',
              'previewImages', 'thumbnail', 'updatedAt'
            ])
        && (
          !('price' in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.resource.data.price is int
            && request.resource.data.price >= 0
            && request.resource.data.price <= 500000
          )
        );

      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;

      // 관리자는 모든 자료 수정/삭제 가능 (성적 인증 등)
      allow update, delete: if isAdmin();
    }

    match /transactions/{txId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.buyerId == request.auth.uid;
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;

      // 신규 리뷰 작성은 Cloud Function (submitReview)에서만 처리하여 구매 검증
      allow create: if false;

      // 본인 리뷰만, rating/content만 수정 가능
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.materialId == resource.data.materialId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rating', 'content', 'updatedAt'])
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 1000;

      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /kakaopay_sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // server only
    }
    match /toss_sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // server only
    }

    match /carts/{cartId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
    }

    match /reports/{reportId} {
      allow read, write: if false; // Cloud Functions only (submit, admin)
    }
    match /withdraw_secrets/{docId} {
      allow read, write: if false; // Cloud Functions only (admin)
    }
    match /verification_sessions/{docId} {
      allow read, write: if false; // Cloud Functions only
    }
    match /admin_logs/{docId} {
      allow read, write: if false; // Cloud Functions only
    }
    match /failed_deletions/{docId} {
      allow read, write: if false; // Cloud Functions only
    }
    match /material_requests/{requestId} {
      allow read: if true;
      allow write: if false; // only via Cloud Functions

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 500;
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }
    match /raffle_entries/{entryId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false; // only via Cloud Functions
    }
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false; // only via Cloud Functions
    }
    match /rate_limits/{docId} {
      allow read, write: if false; // Cloud Functions only
    }
    match /charge_requests/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // only via Cloud Functions
    }
  }
}
