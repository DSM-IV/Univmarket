# Database
DB_PASSWORD=your-secure-password-here

# Redis
REDIS_PASSWORD=your-secure-password-here

# 민감정보(계좌번호 등) AES-GCM 암호화 키
# 생성: openssl rand -base64 32
# 운영 키는 절대 변경 금지 (변경 시 기존 암호문 복호화 불가)
ENCRYPTION_KEY=your-base64-32byte-key-here

# Cloudflare R2 (기존 functions/.env에서 가져오기)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=univmarket
R2_PUBLIC_URL=

# Payment
KAKAOPAY_CID=
KAKAOPAY_SECRET_KEY=
TOSS_SECRET_KEY=

# SMS (Aligo)
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_KEY=
ALIGO_SENDER_NUMBER=

# VirusTotal
VIRUSTOTAL_API_KEY=

# App
FRONTEND_URL=https://unifile.store

# 로컬 개발 전용. 운영 .env 에는 절대 설정 X (또는 false 명시).
# true 이면 localhost:5173/5174/3000 origin이 CORS 허용됨.
ALLOW_LOCALHOST_CORS=false

# 클로즈드 베타 기간 출금 차단 (true). 정식 오픈 시 false 로 변경.
BETA_WITHDRAW_DISABLED=true
